<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>CreateView</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: linear-gradient(135deg, #3c404e, #201d35);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .main-container{
            padding: 40px;
        }

        .container-custom{
            background: rgb(255, 255, 255);
            width: 100%;
            max-width: 500px;
            padding: 40px;
            border-radius: 25px;
            box-shadow: 0 10px 30px rgba(224, 9, 9, 0.1);
        }

        .title{
            text-align: center;
            margin-bottom: 30px;
            color: black;
            font-weight: 700;
        }

        .form-label{
            font-weight: 500;
            color: #555;
        }

        .form-control{
            border-radius: 12px;
            padding: 12px;
            border: 1px solid #ddd;
            transition: 0.3s;
        }

        .form-control:focus{
            border-color: rgb(75, 94, 105);
            box-shadow: 0 0 0 0.2rem rgba(27, 41, 238, 0.301);
        }

        .btn-custom{
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(90deg, #09083d, rgb(45, 38, 68));
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-custom:hover{
            transform: translateY(-2px);
            opacity: 40px;
        }

    </style>

</head>
<body>
    <div class="container-custom">
        <form>
            <h1 class="title">Cadastro de Usuário</h1>
            <div class="mb-3">
                <div>
                    <label for="username" class="form-label">Username</label>
                 </div>
                <div>
                    <input type="text" id="username" class="form-control">
                </div>
            </div>
            <div class="mb-3">
                <div>
                    <label for="email" class="form-label">E-mail</label>
                </div>
                <div>
                    <input type="email" id="email" class="form-control">
                </div>
            </div>
            <div class="mb-4">
                <div>
                    <label for="senha" class="form-label">Senha</label>
                </div>
                <div>
                    <input type="password" id="senha" class="form-control">
                </div>
            </div>
            <div>
                <button id="btnCadastrarUsuario" type="submit" class="btn-custom">Cadastrar</button>
            </div>
        </form>
    </div>
</body>
<script>

    const btnCadastrarUsuario = document.getElementById("btnCadastrarUsuario")
    
    btnCadastrarUsuario.addEventListener("click", cadastrarUsuario)

    async function cadastrarUsuario(e){
        e.preventDefault()

        const username = document.getElementById("username")
        const email = document.getElementById("email")
        const senha = document.getElementById("senha")

        const url = "/user/create"

        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type':'application/json'
            },
            body: JSON.stringify({
                username: username.value,
                email: email.value,
                senha: senha.value
            }
            )
        })

        const data = await response.json()

        if(!response.ok){
            console.log("Ocorreu um erro na requisição") 
        }

        console.log(data)

    }

</script>
</html>
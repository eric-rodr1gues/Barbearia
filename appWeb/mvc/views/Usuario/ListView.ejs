<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>ListView</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: linear-gradient(135deg, #3c404e, #201d35);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .title{
            text-align: center;
            margin-bottom: 30px;
            color: black;
            font-weight: 700;
        }

        .table-container{
            background: white;
            padding: 40px;
            border-radius: 25px;
            width: 60%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .table thead{
            background: black;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            text-decoration: none;
        }

        .btn-edit{
            background: rgb(93, 93, 139);
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            text-decoration: none;
        }

        .btn-delete{
            background: #d33;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
        }

        .btn-edit:hover, .btn-delete:hover{
            opacity: 0.8;
        }

        .sidebar{
            width: 120px;
            background:white;
            height: 100vh;
            padding: 30px 20px;
            box-shadow: 5px 0 20px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
        }

        .logo-area{
            text-align: center;
            margin-bottom: 40px;    
        }

        .logo-title{
            color: rgb(45, 38, 68);
            font-size: 1.0rem;
            font-weight: 700;
        }

        .sidebar-menu{
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .menu-item{
            text-decoration: none;
            color: #555;
            padding: 14px;
            border-radius: 12px;
            transition: 0.3s;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 1.2rem;
        }

        .menu-item:hover{
            background: rgba(93, 93, 139, 0.342);
            color: #50598d;
            transform: translateX(5px);
        }

        .menu-active{
            background: linear-gradient(90deg, #09083d, rgb(45, 38, 68));
            color: white;
        }

        .content{
            margin-left: 260px;
            width: calc(100% - 260px);

            display: flex;
            justify-content: center;
            align-items: center;

            padding: 40px;
        }

        .subtitle{
            text-align: center;
            color: #888;
            margin-top: -15px;
            margin-bottom: 30px;
        }

        @media(max-width: 760px){
            .content{
                margin-left: 100px;
                width: calc(100% - 100px);
                padding: 20px;
            }

            .table-container{
                padding: 20px;
            }

            .title{
                font-size: 2rem;
            }

            .subtitle{
                font-size: 0.9rem;
            }

            .btn-edit,
            .btn-delete{
                padding: 6px 10px;
                font-size: 0.8rem;
            }
        }

    </style>

</head>
<body>
    <div class="sidebar">
        <div class="logo-area">
            <h2 class="logo-title">Barbearia Digital</h2>
        </div>
        <div class="sidebar-menu">
            <a href="/user/create" class="menu-item">
                <i class="bi bi-person-plus"></i>
            </a>
            <a href="/user/list" class="menu-item menu-active">
                <i class="bi bi-person"></i>
            </a>
            <a href="/atendimento/create" class="menu-item">
                <i class="bi bi-calendar-plus"></i>
            </a>
            <a href="/atendimento/list" class="menu-item">
                <i class="bi bi-calendar-check"></i>
            </a>
        </div>
    </div>
    <div class="content">
        <div class="table-container">
            <h1 class="title">Lista de Usuários</h1>
            <p class="subtitle">Acompanhe a lista de Usuários</p>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Senha</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(usuario of usuarios) {%>
                            <tr>
                                <td><%= usuario.id %></td>
                                <td><%= usuario.nome %></td>
                                <td><%= usuario.email %></td>
                                <td><%= usuario.senha %></td>
                                <td class="d-flex gap-2">
                                    <a href="/user/edit/<%= usuario.id %>" class="btn-edit">Editar</a>
                                    <button onclick="apagarUsuario('<%= usuario.id %>')" id="btnApagar" class="btn-delete" type="button">Apagar</button>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>

<script>
    async function apagarUsuario(id){

        const resultado = await Swal.fire({
            title: 'Deseja apagar?',
            text: 'Essa ação não poderá ser desfeita.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: 'rgb(93, 93, 139)',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sim, apagar',
            cancelButtonText: 'Cancelar',
            background: '#fff',
            color: '#555'
        })

        if(resultado.isConfirmed){
           const url = "/user/delete/"+id
            const response = await fetch(url, {method:'DELETE'})

            const data = await response.json()

            if(!response.ok){
                Swal.fire({
                    title: 'Erro!',
                    text: 'Ocorreu um erro ao apagar.',
                    icon: 'error',
                    confirmButtonColor: 'rgb(93, 93, 139)'
                })
                return
            }

            Swal.fire({
                title: 'Apagado!',
                text: 'Usuário removido com sucesso.',
                icon: 'success',
                confirmButtonColor: 'rgb(93, 93, 139)'
            })

            console.log(data)
            setTimeout(() => {
            location.reload() 
            },1200) 
        }
    }
</script>

</html>